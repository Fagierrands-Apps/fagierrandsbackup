# ============================================
# FAGI ERRANDS BACKEND - ENVIRONMENT VARIABLES
# ============================================
# This file serves as a template for required environment variables.
# Copy this file and configure it in your cPanel Environment Variables table.
# DO NOT commit actual credentials to version control.
# ============================================

# ============================================
# DJANGO CORE CONFIGURATION
# ============================================
# Generate a new secret key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=

# Set to False in production, True only for local development
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
PG_DB_NAME=
PG_USER=
PG_PASSWORD=
PG_HOST=
PG_PORT=5432

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# EMAIL CONFIGURATION (Brevo SMTP)
# ============================================
# Sign up at https://www.brevo.com for free SMTP (300 emails/day)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# ============================================
# NCBA PAYMENT GATEWAY
# ============================================
# NCBA Till/Paybill API credentials
NCBA_USERNAME=
NCBA_PASSWORD=
NCBA_PAYBILL_NO=
NCBA_TILL_NO=
NCBA_TRANSACTION_TYPE=CustomerPayBillOnline
NCBA_USE_TILL_AS_ACCOUNT=False

# ============================================
# M-PESA DARAJA API (CRITICAL - NEVER HARDCODE)
# ============================================
# Get credentials from https://developer.safaricom.co.ke
# IMPORTANT: Use sandbox credentials for testing, production for live
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_PARTYB_SHORTCODE=

# ============================================
# SERVER URLS
# ============================================
# Frontend application URL (for CORS and email links)
FRONTEND_URL=

# Backend base URL (for payment callbacks)
BASE_URL=

# ============================================
# ADMIN & NOTIFICATIONS
# ============================================
# Comma-separated list of admin emails for error notifications
ADMIN_EMAILS=admin@yourdomain.com

# Optional: MediaFire integration email
MEDIAFIRE_EMAIL=

# Web push notification email
WEBPUSH_EMAIL=
